# --- Industry ---
# Path to the industry YAML config file
# Included configs: configs/utilities.yaml, configs/ecommerce.yaml, configs/healthcare.yaml
INDUSTRY_CONFIG=configs/utilities.yaml

# --- LLM Provider ---
# "anthropic" for Claude API, "openai" for any OpenAI-compatible API (Ollama, vLLM, llama.cpp, LM Studio, etc.)
LLM_PROVIDER=anthropic

# Base URL for OpenAI-compatible APIs (ignored when LLM_PROVIDER=anthropic)
# Examples:
#   Ollama:      http://localhost:11434/v1
#   vLLM:        http://localhost:8000/v1
#   llama.cpp:   http://localhost:8080/v1
#   LM Studio:   http://localhost:1234/v1
LLM_BASE_URL=http://localhost:11434/v1

# --- API Keys ---
# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible API key (often not needed for local models, set to any value)
OPENAI_API_KEY=not-needed

# --- Model ---
# Model name. Examples:
#   Anthropic:  claude-sonnet-4-20250514
#   Ollama:     llama3.1:8b, mistral, qwen2.5:14b
#   vLLM:       meta-llama/Llama-3.1-8B-Instruct
MODEL_NAME=claude-sonnet-4-20250514

# Max tokens for LLM response
MAX_TOKENS=4096

# Temperature (lower = more deterministic)
TEMPERATURE=0.2

# --- App ---
# Confidence threshold for human review flagging
CONFIDENCE_THRESHOLD=0.6

# Logging level
LOG_LEVEL=INFO
