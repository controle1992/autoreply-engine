# --- Industry ---
# Path to the industry YAML config file
# Included: configs/utilities.yaml, configs/ecommerce.yaml, configs/healthcare.yaml
INDUSTRY_CONFIG=configs/utilities.yaml

# =============================================================================
# LLM PROVIDER
# =============================================================================
# Supported values: "anthropic", "openai", "google"
#
# The "openai" provider works with OpenAI ChatGPT AND any OpenAI-compatible API:
#   DeepSeek, Mistral, xAI (Grok), Groq, Together AI, Fireworks AI,
#   Perplexity, Ollama, vLLM, llama.cpp, LM Studio, and more.
#
LLM_PROVIDER=anthropic

# Base URL for OpenAI-compatible APIs (ignored for anthropic/google providers)
# Leave commented out to use OpenAI's default API (https://api.openai.com/v1)
#
# Provider URLs:
#   OpenAI (default):  (leave empty)
#   DeepSeek:          https://api.deepseek.com/v1
#   Mistral:           https://api.mistral.ai/v1
#   xAI (Grok):        https://api.x.ai/v1
#   Groq:              https://api.groq.com/openai/v1
#   Together AI:       https://api.together.xyz/v1
#   Fireworks AI:      https://api.fireworks.ai/inference/v1
#   Perplexity:        https://api.perplexity.ai
#   Ollama (local):    http://localhost:11434/v1
#   vLLM (local):      http://localhost:8000/v1
#   llama.cpp (local): http://localhost:8080/v1
#   LM Studio (local): http://localhost:1234/v1
#
# LLM_BASE_URL=https://api.deepseek.com/v1

# =============================================================================
# API KEYS (only set the one matching your provider)
# =============================================================================

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible (works for OpenAI, DeepSeek, Mistral, xAI, Groq, Together, Fireworks, Perplexity)
# For local models (Ollama, vLLM, llama.cpp, LM Studio), set to any value or leave as "not-needed"
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...

# =============================================================================
# MODEL
# =============================================================================
# Examples per provider:
#
#   Anthropic:    claude-sonnet-4-20250514, claude-opus-4-6-20250415, claude-haiku-4-5-20251001
#   OpenAI:       gpt-4o, gpt-4o-mini, gpt-4.1, o3-mini
#   Google:       gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
#   DeepSeek:     deepseek-chat, deepseek-reasoner
#   Mistral:      mistral-large-latest, mistral-small-latest, codestral-latest
#   xAI:          grok-3, grok-3-mini
#   Groq:         llama-3.3-70b-versatile, mixtral-8x7b-32768
#   Together:     meta-llama/Llama-3.1-70B-Instruct-Turbo
#   Fireworks:    accounts/fireworks/models/llama-v3p1-70b-instruct
#   Perplexity:   sonar-pro, sonar
#   Ollama:       llama3.1:8b, mistral, qwen2.5:14b
#
MODEL_NAME=claude-sonnet-4-20250514

# Max tokens for LLM response
MAX_TOKENS=4096

# Temperature (lower = more deterministic)
TEMPERATURE=0.2

# =============================================================================
# APP
# =============================================================================

# Confidence threshold for human review flagging
CONFIDENCE_THRESHOLD=0.6

# Logging level
LOG_LEVEL=INFO
